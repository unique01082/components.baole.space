{
  "name": "@baolq/ui",
  "private": false,
  "version": "1.1.6",
  "description": "A rich dark-gradient React component library for the baole.space ecosystem. Ant Design-level prop richness, glassmorphism design system.",
  "author": "Bao LE <bao.lq.it@gmail.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/unique01082/components.baole.space"
  },
  "keywords": [
    "react",
    "components",
    "tailwindcss",
    "design-system",
    "glassmorphism",
    "dark-theme"
  ],
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./style.css": "./dist/style.css",
    "./tailwind-preset": "./tailwind-preset.ts"
  },
  "files": [
    "dist",
    "tailwind-preset.ts",
    "README.md"
  ],
  "sideEffects": [
    "./dist/style.css"
  ],
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "build:lib": "BUILD_TARGET=lib vite build",
    "build:lib:win": "cross-env BUILD_TARGET=lib vite build",
    "prepublishOnly": "pnpm run build:lib:win",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest --coverage",
    "release:patch": "npm version patch -m 'chore: release v%s' && git push origin master --follow-tags",
    "release:minor": "npm version minor -m 'chore: release v%s' && git push origin master --follow-tags",
    "release:major": "npm version major -m 'chore: release v%s' && git push origin master --follow-tags"
